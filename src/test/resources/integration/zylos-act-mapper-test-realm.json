{
  "realm": "zylos-act-mapper-test",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "zylos-gateway",
      "name": "Gateway (mapper attached)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "consentRequired": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-secret-gateway",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": [],
      "webOrigins": [],
      "attributes": {
        "standard.token.exchange.enabled": "true",
        "access.token.signed.response.alg": "RS256"
      },
      "protocolMappers": [
        {
          "name": "gateway-self-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "zylos-gateway",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "pricing-target-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "zylos-internal-pricing",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "zylos-act-claim",
          "protocol": "openid-connect",
          "protocolMapper": "zylos-act-claim-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ],
      "defaultClientScopes": [
        "acr",
        "roles"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "zylos-internal-pricing",
      "name": "Pricing (no mapper attached)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "consentRequired": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-secret-pricing",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": [],
      "webOrigins": [],
      "attributes": {
        "standard.token.exchange.enabled": "true",
        "access.token.signed.response.alg": "RS256"
      },
      "protocolMappers": [
        {
          "name": "pricing-self-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "zylos-internal-pricing",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "gateway-target-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "zylos-gateway",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "acr",
        "roles"
      ],
      "optionalClientScopes": []
    }
  ]
}
